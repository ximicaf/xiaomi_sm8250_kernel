# Platform
CONFIG_MACH_XIAOMI_ALIOTH=n

# Touchscreen
CONFIG_TOUCHSCREEN_FOCALTECH=n
CONFIG_TOUCHSCREEN_XIAOMI_TOUCHFEATURE=n
CONFIG_TOUCHSCREEN_SUPPORT_NEW_GAME_MODE=n

# Fingerprint
CONFIG_INPUT_FINGERPRINT=n
CONFIG_FINGERPRINT_FPC=n
CONFIG_FINGERPRINT_GOODIX=n

# Power
CONFIG_BQ2597X_CHARGE_PUMP=n
CONFIG_BATT_VERIFY_BY_DS28E16=n
CONFIG_ONEWIRE_GPIO=n

# Ultrasound Proximity
CONFIG_US_PROXIMITY=n

# Vibrator
CONFIG_INPUT_AW8697_HAPTIC=n

# Camera
CONFIG_TECHPACK_CAMERA_XIAOMI=n
